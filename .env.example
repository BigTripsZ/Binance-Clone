# Neon Database URL
DATABASE_URL=postgresql://user:password@host/database

# API Configuration
VITE_API_URL=http://localhost:3001

# Admin Dashboard Access - SECURITY CRITICAL
# Set a secure 6-character alphanumeric code for admin dashboard access
# NO default/hardcoded values - must be explicitly set in environment
# This is required to access the /admin/dash route
VITE_ADMIN_ACCESS_CODE=YOURSECRETCODE

# Server Port
PORT=3001
